---
import { Image } from 'astro:assets';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import { gallerySections } from '../../data/sections';
import { sortByFilename } from '../../utils/images';

export const getStaticPaths: GetStaticPaths = () =>
  gallerySections.map(({ slug, label, description }) => ({
    params: { slug },
    props: { label, description },
  }));

interface Props {
  label: string;
  description: string;
}

const { slug } = Astro.params;
const { label, description } = Astro.props;

type ImageModule = { default: ImageMetadata };

// Glob all images across all section folders (pattern must be static)
const allImages = import.meta.glob<ImageModule>(
  '../../assets/galleries/**/*.{jpg,jpeg,png,webp,JPG,JPEG}'
);

// Filter to only this section's folder and sort by filename
const images = await Promise.all(
  sortByFilename(
    Object.keys(allImages).filter((key) => key.includes(`/galleries/${slug}/`))
  ).map(async (key, idx) => {
    const mod = await allImages[key]();
    return { img: mod.default, idx };
  })
);
---

<BaseLayout
  title={`${label} — Jamie Ian Genovese`}
  description={description}
>
  <div class="flex h-screen overflow-hidden overscroll-none">
    <Nav />

    <main
      id="gallery"
      class="flex-1 h-full overflow-x-auto overflow-y-hidden overscroll-x-contain flex items-stretch scroll-smooth"
      style="scroll-snap-type: x mandatory;"
      aria-label={`${label} photo gallery`}
    >
      <!-- Section heading — first "slide" -->
      <div
        class="h-full shrink-0 flex flex-col justify-center px-12 border-r border-gray-100 dark:border-gray-800 dark:bg-gray-950"
        style="scroll-snap-align: start; min-width: 280px;"
      >
        <h1 class="font-display text-4xl font-bold text-brand dark:text-gray-100 mb-3">{label}</h1>
        <p class="text-brand-muted dark:text-gray-400 text-sm max-w-xs">{description}</p>
      </div>

      {images.length === 0 && (
        <div
          class="h-full shrink-0 flex flex-col justify-center px-12 text-brand-muted dark:text-gray-500"
          style="scroll-snap-align: start; min-width: 320px;"
        >
          <p class="text-lg">No photos yet.</p>
          <p class="text-sm mt-2">
            Add images to <code class="bg-gray-100 dark:bg-gray-800 px-1 rounded">src/assets/galleries/{slug}/</code>
          </p>
        </div>
      )}

      {images.map(({ img, idx }) => (
        <figure class="h-full shrink-0 m-0" style="scroll-snap-align: start;">
          <Image
            src={img}
            alt={`${label} — photograph ${idx + 1}`}
            class="h-full w-auto object-cover"
            loading="eager"
            fetchpriority={idx < 2 ? 'high' : 'low'}
            format="webp"
            quality={82}
          />
        </figure>
      ))}

      <!-- Back-to-start -->
      <div class="flex items-center px-4 shrink-0">
        <button
          onclick="document.getElementById('gallery').scrollTo({ left: 0, behavior: 'smooth' })"
          aria-label="Back to start"
          class="p-2 text-brand-muted dark:text-gray-500 hover:text-brand dark:hover:text-gray-100 transition-colors"
        >
          <svg class="w-8 h-8 rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 5l7 7-7 7M5 5l7 7-7 7"/>
          </svg>
        </button>
      </div>
    </main>
  </div>
</BaseLayout>

