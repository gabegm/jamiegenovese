---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
---

<BaseLayout
  title="Contact — Jamie Ian Genovese"
  description="Get in touch with Jamie Ian Genovese."
>
  <div class="flex h-screen overflow-hidden">
    <Nav />

    <main class="flex-1 overflow-y-auto px-12 py-10 max-w-2xl">
      <h1 class="font-display text-3xl font-bold text-brand dark:text-gray-100 mb-2">Contact</h1>
      <p class="text-brand-muted dark:text-gray-400 mb-8">Fill in the form below and I'll get back to you as soon as possible.</p>

      <!--
        Netlify Forms: add `data-netlify="true"` and the form is handled automatically.
        Fallback: replace action with a Formspree endpoint (https://formspree.io).
      -->
      <form
        name="contact"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        class="space-y-5"
      >
        <!-- Honeypot (anti-spam) -->
        <input type="hidden" name="form-name" value="contact" />
        <p class="hidden">
          <label>Don't fill this out: <input name="bot-field" /></label>
        </p>

        <div>
          <label for="name" class="block text-sm font-semibold text-brand dark:text-gray-200 mb-1">Name</label>
          <input
            id="name"
            name="name"
            type="text"
            required
            autocomplete="name"
            class="w-full border border-gray-300 dark:border-gray-600 rounded px-3 py-2 text-brand dark:text-gray-100 bg-white dark:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-brand dark:focus:ring-gray-400"
          />
        </div>

        <div>
          <label for="email" class="block text-sm font-semibold text-brand dark:text-gray-200 mb-1">Email</label>
          <input
            id="email"
            name="email"
            type="email"
            required
            autocomplete="email"
            class="w-full border border-gray-300 dark:border-gray-600 rounded px-3 py-2 text-brand dark:text-gray-100 bg-white dark:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-brand dark:focus:ring-gray-400"
          />
        </div>

        <div>
          <label for="subject" class="block text-sm font-semibold text-brand dark:text-gray-200 mb-1">Subject</label>
          <input
            id="subject"
            name="subject"
            type="text"
            class="w-full border border-gray-300 dark:border-gray-600 rounded px-3 py-2 text-brand dark:text-gray-100 bg-white dark:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-brand dark:focus:ring-gray-400"
          />
        </div>

        <div>
          <label for="message" class="block text-sm font-semibold text-brand dark:text-gray-200 mb-1">Message</label>
          <textarea
            id="message"
            name="message"
            required
            rows="5"
            class="w-full border border-gray-300 dark:border-gray-600 rounded px-3 py-2 text-brand dark:text-gray-100 bg-white dark:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-brand dark:focus:ring-gray-400 resize-y"
          ></textarea>
        </div>

        <button
          type="submit"
          class="px-6 py-2 bg-brand dark:bg-gray-700 text-white font-semibold rounded hover:bg-brand/80 dark:hover:bg-gray-600 transition-colors"
        >
          Send message
        </button>
      </form>
    </main>
  </div>
</BaseLayout>
