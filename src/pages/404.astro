---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
---

<BaseLayout
  title="Page not found — Jamie Ian Genovese"
  description="The page you're looking for doesn't exist."
>
  <div class="flex h-screen overflow-hidden">
    <Nav />

    <main class="flex-1 flex flex-col items-center justify-center px-12 text-center">
      <p class="text-7xl font-display font-bold text-gray-100 dark:text-gray-800 mb-4" aria-hidden="true">404</p>
      <h1 class="text-2xl font-display font-bold text-brand dark:text-gray-100 mb-3">Page not found</h1>
      <p class="text-brand-muted dark:text-gray-400 mb-8">The page you're looking for doesn't exist or has been moved.</p>
      <a
        href="/"
        class="px-5 py-2 bg-brand dark:bg-gray-700 text-white font-semibold rounded hover:bg-brand/80 dark:hover:bg-gray-600 transition-colors"
      >
        Back to gallery
      </a>
    </main>
  </div>
</BaseLayout>
