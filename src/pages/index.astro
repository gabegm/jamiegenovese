---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';

// All gallery images
const images = Array.from({ length: 39 }, (_, i) => ({
  src: `/img/daniela_${i + 1}.jpg`,
  alt: `Jamie Ian Genovese — photograph ${i + 1}`,
}));
---

<BaseLayout
  title="Jamie Ian Genovese — Visual Arts"
  description="Portfolio of Jamie Ian Genovese, photographer and visual artist."
>
  <div class="flex h-screen overflow-hidden">
    <Nav />

    <main
      id="gallery"
      class="flex-1 h-full overflow-x-auto overflow-y-hidden flex items-stretch scroll-smooth"
      style="scroll-snap-type: x mandatory;"
      aria-label="Photo gallery"
    >
      {images.map(({ src, alt }, idx) => (
        <figure
          class="h-full shrink-0 m-0"
          style="scroll-snap-align: start;"
        >
          <img
            src={src}
            alt={alt}
            class="h-full w-auto object-cover"
            loading={idx < 3 ? 'eager' : 'lazy'}
            decoding="async"
          />
        </figure>
      ))}

      <!-- Back-to-start button -->
      <div class="flex items-center px-4 shrink-0">
        <button
          onclick="document.getElementById('gallery').scrollTo({ left: 0, behavior: 'smooth' })"
          aria-label="Back to start"
          class="p-2 text-brand-muted hover:text-brand transition-colors"
        >
          <svg class="w-8 h-8 rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 5l7 7-7 7M5 5l7 7-7 7"/>
          </svg>
        </button>
      </div>
    </main>
  </div>
</BaseLayout>
